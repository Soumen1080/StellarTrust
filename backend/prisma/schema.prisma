// StellarTrust — Prisma schema (Postgres / Supabase).
//
// Models the complete persistable domain across every bounded context:
// identity/auth, KYC, ledger (double-entry), payments/escrow, disputes,
// cross-border settlement, RWA tokenization, reputation, and audit.
//
// Contracts of record live in @stellartrust/shared (src/constants + src/types);
// the enums and columns below mirror those DTOs exactly. Enum labels match the
// wire/string values the app already uses, so the existing raw-`pg`
// repositories (e.g. pg-auth, pg-identity) interoperate with these tables.
//
// Conventions:
//   * UUID PKs default to gen_random_uuid() at the DB level so both Prisma and
//     raw SQL inserts (which omit the id) work.
//   * Monetary amounts and unit counts are BigInt (Postgres BIGINT) — exact
//     integer minor units, never floats.
//   * Timestamps are timestamptz; created_at/updated_at have DB defaults.
//   * Structured value snapshots (AI advisory, provider checks, route plans,
//     opaque metadata) are stored as JSONB.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────────────────────
// Enums (mirror shared/src/constants — labels are the exact stored values)
// ─────────────────────────────────────────────────────────────────────────────

enum CustodyType {
  self
  contract
}

enum KycStatus {
  pending
  under_review
  verified
  rejected
}

enum ReviewStatus {
  queued
  resolved
}

enum HumanKycDecision {
  approve
  reject
}

enum CurrencyCode {
  USD
  EUR
  INR
  NGN
  XLM
  USDC
}

enum LedgerAccountType {
  asset
  liability
  equity
  revenue
  expense
}

enum EntryDirection {
  debit
  credit
}

enum ChainTxStatus {
  pending
  submitted
  success
  failed
}

enum OrderStatus {
  created
  accepted
  deposited
  locked
  confirmed
  released
  refunded
  disputed
  cancelled
}

enum EscrowState {
  locked
  released
  refunded
  disputed
}

enum PaymentTransitionType {
  create
  accept
  deposit
  lock
  confirm
  release
  refund
}

enum DisputeStatus {
  open
  evidence_window
  under_review
  resolved
}

enum DisputeResolution {
  release
  refund
}

enum DisputeDecisionMaker {
  auto_policy
  human
}

enum EvidenceKind {
  invoice
  tracking
  otp
  courier
  image
}

enum SettlementStatus {
  quoted
  deposit_pending
  converting
  payout_pending
  completed
  failed
}

enum SettlementTransitionType {
  deposit
  convert
  payout
}

enum AnchorProtocol {
  sep6
  sep24
  sep31
}

enum AnchorTransferStatus {
  pending
  completed
  failed
}

enum AnchorTransferKind {
  deposit
  withdrawal
}

enum AssetType {
  invoice
  commodity
  real_estate
  other
}

enum TokenizationStatus {
  draft
  active
  funded
  distributing
  distributed
  frozen
  cancelled
}

enum PayoutStatus {
  pending
  processing
  completed
  failed
}

// ─────────────────────────────────────────────────────────────────────────────
// Identity & Auth
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email              String    @unique
  displayName        String?   @map("display_name")
  kycStatus          KycStatus @default(pending) @map("kyc_status")
  // Snapshot of the latest KycApplicationResponse (JSON) for fast profile reads.
  latestVerification Json?     @map("latest_verification")
  verifiedAt         DateTime? @map("verified_at") @db.Timestamptz(6)
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  wallets            Wallet[]
  businesses         Business[]
  sessions           AuthSession[]
  ordersAsBuyer      Order[]             @relation("OrderBuyer")
  ordersAsSeller     Order[]             @relation("OrderSeller")
  paymentTransitions PaymentTransition[]
  disputesOpened     Dispute[]
  disputeEvidence    DisputeEvidence[]
  settlements        Settlement[]
  assets             Asset[]
  tokenizations      Tokenization[]
  tokenHoldings      TokenHolding[]
  payoutRecords      PayoutRecord[]
  reputation         Reputation?
  kycVerifications   KycVerification[]
  kycReviews         KycReview[]

  @@map("users")
}

model Business {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerUserId String   @map("owner_user_id") @db.Uuid
  legalName   String   @map("legal_name")
  country     String
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  owner User @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)

  @@index([ownerUserId])
  @@map("businesses")
}

model Wallet {
  id               String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String      @map("user_id") @db.Uuid
  stellarPublicKey String      @unique @map("stellar_public_key")
  custodyType      CustodyType @default(self) @map("custody_type")
  createdAt        DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions AuthSession[]

  @@index([userId])
  @@map("wallets")
}

model Sep10Challenge {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  stellarPublicKey  String    @map("stellar_public_key")
  transactionHash   String    @map("transaction_hash")
  networkPassphrase String    @map("network_passphrase")
  expiresAt         DateTime  @map("expires_at") @db.Timestamptz(6)
  consumedAt        DateTime? @map("consumed_at") @db.Timestamptz(6)
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([stellarPublicKey])
  @@index([expiresAt])
  @@map("sep10_challenges")
}

model AuthSession {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  walletId  String    @map("wallet_id") @db.Uuid
  // Only the SHA-256 hash of the opaque bearer token is stored, never the token.
  tokenHash String    @unique @map("token_hash")
  roles     String[]  @default([])
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("auth_sessions")
}

// ─────────────────────────────────────────────────────────────────────────────
// KYC / KYB
// ─────────────────────────────────────────────────────────────────────────────

model KycVerification {
  // id == verificationId (app-generated UUID).
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String    @map("user_id") @db.Uuid
  providerReference String    @map("provider_reference")
  status            KycStatus
  // KycProviderChecks (document/ocr/faceMatch/liveness/aml) snapshot.
  checks            Json
  // KycRiskAdvisory (riskScore/decision/confidence/explanation/signals) snapshot.
  advisory          Json
  submittedAt       DateTime  @map("submitted_at") @db.Timestamptz(6)
  // Development-only auto-approval timestamp (never set in production).
  autoApproveAt     DateTime? @map("auto_approve_at") @db.Timestamptz(6)
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviews KycReview[]

  @@index([userId])
  @@index([status])
  @@map("kyc_verifications")
}

model KycReview {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  verificationId   String            @map("verification_id") @db.Uuid
  userId           String            @map("user_id") @db.Uuid
  status           ReviewStatus      @default(queued)
  advisory         Json
  providerChecks   Json              @map("provider_checks")
  resolvedBy       String?           @map("resolved_by")
  resolution       HumanKycDecision?
  resolutionReason String?           @map("resolution_reason")
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  resolvedAt       DateTime?         @map("resolved_at") @db.Timestamptz(6)

  verification KycVerification @relation(fields: [verificationId], references: [id], onDelete: Cascade)
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([verificationId])
  @@index([userId])
  @@index([status])
  @@map("kyc_reviews")
}

// ─────────────────────────────────────────────────────────────────────────────
// Ledger (double-entry). Every money movement writes a balanced transaction.
// ─────────────────────────────────────────────────────────────────────────────

model LedgerAccount {
  id       String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type     LedgerAccountType
  currency CurrencyCode
  ownerRef String?           @map("owner_ref")
  name     String

  entries LedgerEntry[]

  @@index([type])
  @@map("ledger_accounts")
}

model LedgerTransaction {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  // Idempotency / correlation key — unique to prevent double-posting.
  referenceId String   @unique @map("reference_id")
  description String
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  entries              LedgerEntry[]
  stellarTransactions  StellarTransaction[]
  paymentTransition    PaymentTransition?
  settlementTransition SettlementTransition?
  payoutDistribution   PayoutDistribution?

  @@map("ledger_transactions")
}

model LedgerEntry {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  transactionId String         @map("transaction_id") @db.Uuid
  accountId     String         @map("account_id") @db.Uuid
  direction     EntryDirection
  // Positive minor-unit amount for this leg.
  amount        BigInt
  currency      CurrencyCode
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)

  transaction  LedgerTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  account      LedgerAccount     @relation(fields: [accountId], references: [id])
  payoutRecord PayoutRecord?

  @@index([transactionId])
  @@index([accountId])
  @@map("ledger_entries")
}

// ─────────────────────────────────────────────────────────────────────────────
// Stellar / chain transaction records (reconciliation)
// ─────────────────────────────────────────────────────────────────────────────

model StellarTransaction {
  id                  String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hash                String?
  type                String
  status              ChainTxStatus @default(pending)
  ledgerTransactionId String?       @map("ledger_transaction_id") @db.Uuid
  createdAt           DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)

  ledgerTransaction    LedgerTransaction?    @relation(fields: [ledgerTransactionId], references: [id])
  paymentTransition    PaymentTransition?
  settlementTransition SettlementTransition?

  @@index([ledgerTransactionId])
  @@index([hash])
  @@map("stellar_transactions")
}

// ─────────────────────────────────────────────────────────────────────────────
// Payments / Escrow
// ─────────────────────────────────────────────────────────────────────────────

model Order {
  id        String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  buyerId   String       @map("buyer_id") @db.Uuid
  sellerId  String       @map("seller_id") @db.Uuid
  amount    BigInt
  currency  CurrencyCode
  status    OrderStatus  @default(created)
  createdAt DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  buyer               User                     @relation("OrderBuyer", fields: [buyerId], references: [id])
  seller              User                     @relation("OrderSeller", fields: [sellerId], references: [id])
  escrow              Escrow?
  transitions         PaymentTransition[]
  mismatches          ReconciliationMismatch[]
  disputes            Dispute[]
  tokenizations       Tokenization[]
  payoutDistributions PayoutDistribution[]

  @@index([buyerId])
  @@index([sellerId])
  @@index([status])
  @@map("orders")
}

model Escrow {
  id         String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId    String      @unique @map("order_id") @db.Uuid
  contractId String?     @map("contract_id")
  state      EscrowState @default(locked)
  createdAt  DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  order    Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  disputes Dispute[]

  @@index([contractId])
  @@map("escrows")
}

model PaymentTransition {
  id                   String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId              String                @map("order_id") @db.Uuid
  transition           PaymentTransitionType
  actorId              String                @map("actor_id") @db.Uuid
  ledgerTransactionId  String                @unique @map("ledger_transaction_id") @db.Uuid
  stellarTransactionId String                @unique @map("stellar_transaction_id") @db.Uuid
  createdAt            DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)

  order              Order                    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  actor              User                     @relation(fields: [actorId], references: [id])
  ledgerTransaction  LedgerTransaction        @relation(fields: [ledgerTransactionId], references: [id])
  stellarTransaction StellarTransaction       @relation(fields: [stellarTransactionId], references: [id])
  mismatches         ReconciliationMismatch[]

  @@index([orderId])
  @@index([actorId])
  @@map("payment_transitions")
}

model ReconciliationMismatch {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId      String    @map("order_id") @db.Uuid
  transitionId String    @map("transition_id") @db.Uuid
  reason       String
  resolvedAt   DateTime? @map("resolved_at") @db.Timestamptz(6)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  order      Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  transition PaymentTransition @relation(fields: [transitionId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([transitionId])
  @@index([resolvedAt])
  @@map("reconciliation_mismatches")
}

// ─────────────────────────────────────────────────────────────────────────────
// Disputes + AI advisory (Phase 4)
// ─────────────────────────────────────────────────────────────────────────────

model Dispute {
  id                     String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId                String                @map("order_id") @db.Uuid
  escrowId               String?               @map("escrow_id") @db.Uuid
  status                 DisputeStatus         @default(evidence_window)
  amount                 BigInt
  currency               CurrencyCode
  openedBy               String                @map("opened_by") @db.Uuid
  reason                 String
  // Latest AiAdvisory snapshot (reproducible from stored evidence).
  advisory               Json?
  autoResolvable         Boolean               @default(false) @map("auto_resolvable")
  // Flattened DisputeResolutionDTO (null until resolved).
  resolutionOutcome      DisputeResolution?    @map("resolution_outcome")
  resolutionDecidedBy    DisputeDecisionMaker? @map("resolution_decided_by")
  resolutionActor        String?               @map("resolution_actor")
  resolutionReason       String?               @map("resolution_reason")
  resolutionDecidedAt    DateTime?             @map("resolution_decided_at") @db.Timestamptz(6)
  evidenceWindowClosesAt DateTime              @map("evidence_window_closes_at") @db.Timestamptz(6)
  createdAt              DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime              @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  order        Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  escrow       Escrow?           @relation(fields: [escrowId], references: [id])
  openedByUser User              @relation(fields: [openedBy], references: [id])
  evidence     DisputeEvidence[]

  @@index([orderId])
  @@index([openedBy])
  @@index([status])
  @@map("disputes")
}

model DisputeEvidence {
  id          String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  disputeId   String            @map("dispute_id") @db.Uuid
  kind        EvidenceKind
  supports    DisputeResolution
  // Bounded 0..1 advisory strength.
  weight      Float
  // Opaque storage handle (e.g. "storage://..."). Never raw content/PII.
  reference   String
  description String?
  submittedBy String            @map("submitted_by") @db.Uuid
  createdAt   DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)

  dispute         Dispute @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  submittedByUser User    @relation(fields: [submittedBy], references: [id])

  @@index([disputeId])
  @@index([submittedBy])
  @@map("dispute_evidence")
}

// ─────────────────────────────────────────────────────────────────────────────
// Cross-border settlement (Phase 3)
// ─────────────────────────────────────────────────────────────────────────────

model SettlementQuote {
  id               String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  corridorId       String       @map("corridor_id")
  sourceAmount     BigInt       @map("source_amount")
  sourceCurrency   CurrencyCode @map("source_currency")
  // Selected best SettlementRouteDTO snapshot.
  route            Json
  // All considered routes (best-first) for transparency/auditability.
  consideredRoutes Json         @map("considered_routes")
  maxSlippageBps   Int          @map("max_slippage_bps")
  maxFeeAmount     BigInt?      @map("max_fee_amount")
  expiresAt        DateTime     @map("expires_at") @db.Timestamptz(6)
  createdAt        DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)

  settlement Settlement?

  @@index([corridorId])
  @@index([expiresAt])
  @@map("settlement_quotes")
}

model Settlement {
  id                   String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId               String           @map("user_id") @db.Uuid
  quoteId              String           @unique @map("quote_id") @db.Uuid
  corridorId           String           @map("corridor_id")
  status               SettlementStatus @default(quoted)
  sourceAmount         BigInt           @map("source_amount")
  sourceCurrency       CurrencyCode     @map("source_currency")
  destinationAmount    BigInt           @map("destination_amount")
  destinationCurrency  CurrencyCode     @map("destination_currency")
  route                Json
  // Opaque beneficiary reference (never raw bank/PII).
  destinationReference String           @map("destination_reference")
  createdAt            DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime         @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  user        User                               @relation(fields: [userId], references: [id])
  quote       SettlementQuote                    @relation(fields: [quoteId], references: [id])
  transitions SettlementTransition[]
  mismatches  SettlementReconciliationMismatch[]

  @@index([userId])
  @@index([corridorId])
  @@index([status])
  @@map("settlements")
}

model AnchorTransfer {
  id         String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  kind       AnchorTransferKind
  protocol   AnchorProtocol
  status     AnchorTransferStatus @default(pending)
  amount     BigInt
  currency   CurrencyCode
  // Opaque anchor-side reference id.
  reference  String
  // SEP-12 customer id used for this transfer.
  customerId String               @map("customer_id")
  createdAt  DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)

  settlementTransition SettlementTransition?

  @@index([status])
  @@map("anchor_transfers")
}

model SettlementTransition {
  id                   String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  settlementId         String                   @map("settlement_id") @db.Uuid
  transition           SettlementTransitionType
  ledgerTransactionId  String                   @unique @map("ledger_transaction_id") @db.Uuid
  anchorTransferId     String?                  @unique @map("anchor_transfer_id") @db.Uuid
  stellarTransactionId String?                  @unique @map("stellar_transaction_id") @db.Uuid
  createdAt            DateTime                 @default(now()) @map("created_at") @db.Timestamptz(6)

  settlement         Settlement                         @relation(fields: [settlementId], references: [id], onDelete: Cascade)
  ledgerTransaction  LedgerTransaction                  @relation(fields: [ledgerTransactionId], references: [id])
  anchorTransfer     AnchorTransfer?                    @relation(fields: [anchorTransferId], references: [id])
  stellarTransaction StellarTransaction?                @relation(fields: [stellarTransactionId], references: [id])
  mismatches         SettlementReconciliationMismatch[]

  @@index([settlementId])
  @@map("settlement_transitions")
}

model SettlementReconciliationMismatch {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  settlementId String    @map("settlement_id") @db.Uuid
  transitionId String    @map("transition_id") @db.Uuid
  reason       String
  resolvedAt   DateTime? @map("resolved_at") @db.Timestamptz(6)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  settlement Settlement           @relation(fields: [settlementId], references: [id], onDelete: Cascade)
  transition SettlementTransition @relation(fields: [transitionId], references: [id], onDelete: Cascade)

  @@index([settlementId])
  @@index([transitionId])
  @@index([resolvedAt])
  @@map("settlement_reconciliation_mismatches")
}

// ─────────────────────────────────────────────────────────────────────────────
// RWA tokenization (Phase 5)
// ─────────────────────────────────────────────────────────────────────────────

model Asset {
  id                String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerUserId       String       @map("owner_user_id") @db.Uuid
  assetType         AssetType    @map("asset_type")
  // Opaque asset reference (e.g. "invoice:INV-001"). Never raw PII.
  assetRef          String       @map("asset_ref")
  description       String
  valuationAmount   BigInt       @map("valuation_amount")
  valuationCurrency CurrencyCode @map("valuation_currency")
  // Opaque metadata refs (documents, appraisals). Never raw content.
  metadata          Json?
  createdAt         DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  owner         User           @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  tokenizations Tokenization[]

  @@unique([ownerUserId, assetRef])
  @@index([ownerUserId])
  @@map("assets")
}

model Tokenization {
  id                   String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assetId              String             @map("asset_id") @db.Uuid
  issuerUserId         String             @map("issuer_user_id") @db.Uuid
  // Deployed Soroban contract address (null until deployed).
  contractId           String?            @map("contract_id")
  contractDeployedAt   DateTime?          @map("contract_deployed_at") @db.Timestamptz(6)
  totalUnits           BigInt             @map("total_units")
  unitsSold            BigInt             @default(0) @map("units_sold")
  pricePerUnitAmount   BigInt             @map("price_per_unit_amount")
  pricePerUnitCurrency CurrencyCode       @map("price_per_unit_currency")
  requireAuthorization Boolean            @default(false) @map("require_authorization")
  frozen               Boolean            @default(false)
  linkedOrderId        String?            @map("linked_order_id") @db.Uuid
  status               TokenizationStatus @default(draft)
  createdAt            DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime           @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  asset         Asset                @relation(fields: [assetId], references: [id], onDelete: Cascade)
  issuer        User                 @relation(fields: [issuerUserId], references: [id])
  linkedOrder   Order?               @relation(fields: [linkedOrderId], references: [id])
  holdings      TokenHolding[]
  distributions PayoutDistribution[]

  @@index([assetId])
  @@index([issuerUserId])
  @@index([linkedOrderId])
  @@index([status])
  @@map("tokenizations")
}

model TokenHolding {
  id               String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tokenizationId   String       @map("tokenization_id") @db.Uuid
  holderUserId     String       @map("holder_user_id") @db.Uuid
  // Stellar address holding the units.
  holderAddress    String       @map("holder_address")
  units            BigInt
  purchaseAmount   BigInt       @map("purchase_amount")
  purchaseCurrency CurrencyCode @map("purchase_currency")
  purchasedAt      DateTime     @map("purchased_at") @db.Timestamptz(6)
  authorized       Boolean      @default(true)
  updatedAt        DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  tokenization Tokenization @relation(fields: [tokenizationId], references: [id], onDelete: Cascade)
  holder       User         @relation(fields: [holderUserId], references: [id])

  @@unique([tokenizationId, holderUserId])
  @@index([tokenizationId])
  @@index([holderUserId])
  @@map("token_holdings")
}

model PayoutDistribution {
  id                    String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tokenizationId        String       @map("tokenization_id") @db.Uuid
  triggeredByOrderId    String?      @map("triggered_by_order_id") @db.Uuid
  triggeredByTransition String?      @map("triggered_by_transition")
  totalAmount           BigInt       @map("total_amount")
  totalCurrency         CurrencyCode @map("total_currency")
  status                PayoutStatus @default(pending)
  ledgerTransactionId   String?      @unique @map("ledger_transaction_id") @db.Uuid
  initiatedAt           DateTime     @default(now()) @map("initiated_at") @db.Timestamptz(6)
  completedAt           DateTime?    @map("completed_at") @db.Timestamptz(6)

  tokenization      Tokenization       @relation(fields: [tokenizationId], references: [id], onDelete: Cascade)
  triggeredByOrder  Order?             @relation(fields: [triggeredByOrderId], references: [id])
  ledgerTransaction LedgerTransaction? @relation(fields: [ledgerTransactionId], references: [id])
  records           PayoutRecord[]

  @@index([tokenizationId])
  @@index([triggeredByOrderId])
  @@index([status])
  @@map("payout_distributions")
}

model PayoutRecord {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  distributionId String       @map("distribution_id") @db.Uuid
  holderUserId   String       @map("holder_user_id") @db.Uuid
  unitsHeld      BigInt       @map("units_held")
  shareAmount    BigInt       @map("share_amount")
  shareCurrency  CurrencyCode @map("share_currency")
  ledgerEntryId  String?      @unique @map("ledger_entry_id") @db.Uuid
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)

  distribution PayoutDistribution @relation(fields: [distributionId], references: [id], onDelete: Cascade)
  holder       User               @relation(fields: [holderUserId], references: [id])
  ledgerEntry  LedgerEntry?       @relation(fields: [ledgerEntryId], references: [id])

  @@index([distributionId])
  @@index([holderUserId])
  @@map("payout_records")
}

// ─────────────────────────────────────────────────────────────────────────────
// Reputation (Phase 6) — aggregate, non-PII counters. Score is derived, not stored.
// ─────────────────────────────────────────────────────────────────────────────

model Reputation {
  userId          String   @id @map("user_id") @db.Uuid
  ordersCompleted Int      @default(0) @map("orders_completed")
  disputesWon     Int      @default(0) @map("disputes_won")
  disputesLost    Int      @default(0) @map("disputes_lost")
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("reputations")
}

// ─────────────────────────────────────────────────────────────────────────────
// Audit — append-only. Safe metadata only (no PII, tokens, or document values).
// ─────────────────────────────────────────────────────────────────────────────

model AuditEvent {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  // e.g. "user:<id>", "system:kyc-decision-engine", "ai:dispute-advisory".
  actor     String
  action    String
  entity    String
  entityId  String?  @map("entity_id")
  metadata  Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_events")
}
