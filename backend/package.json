{
  "name": "@stellartrust/backend",
  "version": "0.0.0",
  "private": true,
  "description": "StellarTrust API — modular monolith (Express + TypeScript). Bounded contexts per portion.",
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "build": "npm run build:shared && npm run build:backend",
    "build:shared": "npm install --prefix ../shared --include=dev --no-audit --no-fund && npm run build --prefix ../shared",
    "build:backend": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@stellar/stellar-sdk": "16.0.1",
    "@stellartrust/shared": "file:../shared",
    "@supabase/supabase-js": "2.110.7",
    "dotenv": "17.4.2",
    "express": "5.2.1",
    "express-rate-limit": "8.6.0",
    "helmet": "8.3.0",
    "jose": "6.2.3",
    "pg": "8.22.0",
    "pino": "10.3.1",
    "pino-http": "11.0.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/express": "5.0.6",
    "@types/node": "24.3.0",
    "@types/pg": "8.20.0",
    "@types/supertest": "6.0.2",
    "eslint": "9.13.0",
    "rimraf": "6.0.1",
    "supertest": "7.2.2",
    "tsx": "4.23.1",
    "typescript": "5.5.4",
    "typescript-eslint": "8.64.0",
    "vitest": "3.2.4"
  }
}
