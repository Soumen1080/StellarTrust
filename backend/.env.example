# StellarTrust backend — environment template.
# ⚠️  NEVER put real secret keys here or in any committed file (Rules.md #2).
# Secrets are resolved at runtime from a secret manager / KMS boundary.
# Values below are non-secret config or *references* to secrets.

# ── Server ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=8080
LOG_LEVEL=info
# Exact browser origin allowed by the API CORS boundary.
FRONTEND_ORIGIN=http://localhost:3000
# Additional comma-separated deployed frontend origins (env-driven; no
# deployment URLs are hardcoded in source). Leave empty for local-only.
FRONTEND_ORIGINS=

# ── Database (Supabase / Postgres) ──────────────────────────────────────────
# In real environments this comes from the secret manager, not this file.
# Supabase → Settings → Database → Connection string (contains the DB password).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/stellartrust

# ── Redis (jobs / idempotency store in later phases) ────────────────────────
REDIS_URL=redis://localhost:6379

# ── Supabase project (Auth / Storage / API) ─────────────────────────────────
# Optional in Phase 0. Used by the Supabase admin client + JWKS auth verifier.
# SUPABASE_SECRET_KEY is a SERVER-ONLY secret — never expose it to the client
# and never commit a real value (put it in a local .env / secret manager).
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_JWKS_URL=

# ── Stellar network ─────────────────────────────────────────────────────────
STELLAR_NETWORK=testnet
HORIZON_URL=https://horizon-testnet.stellar.org
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# ── Signing boundary (KMS/HSM) ──────────────────────────────────────────────
# NO secret keys in env. Provide the *provider* and a *key reference/ARN* only.
# provider = local-stub | aws-kms | gcp-kms
SIGNER_PROVIDER=local-stub
# e.g. arn:aws:kms:us-east-1:123456789012:key/abcd-...  (a reference, not a key)
SIGNER_KEY_REF=local-stub-key-ref

# ── Development / demo shortcuts (see devlopement.md §6/§7) ──────────────────
# DEMO_MODE unlocks a STABLE testnet-only signer loaded from DEMO_SIGNER_SECRET
# so deployed demos work without KMS. Forbidden on the public network. Real
# production signing must use SIGNER_PROVIDER=aws-kms|gcp-kms instead.
DEMO_MODE=false
# Stellar TESTNET secret seed (S...) for the demo signer. Put the real value in
# the host secret manager, NEVER commit it. Fund this account on testnet.
# DEMO_SIGNER_SECRET=S...
# Auto-verify KYC after a short delay for smooth development. Ignored in
# production regardless of value.
KYC_AUTO_APPROVE=false
KYC_AUTO_APPROVE_DELAY_MS=10000

# ── AI Risk Service (advisory) ──────────────────────────────────────────────
AI_SERVICE_URL=http://localhost:8000

# ── Auth / SEP-10 ───────────────────────────────────────────────────────────
# Dev bearer is used only when no real verifier is configured; tests also use it
# for the compliance-review fixture. Real users authenticate by signing SEP-10.
AUTH_DEV_BEARER=dev-local-token
# Optional development-only wallet account. It still must sign the SEP-10
# challenge; when authenticated it receives user + compliance access.
# AUTH_DEMO_WALLET=G...
AUTH_DEMO_NAME=sam
SEP10_HOME_DOMAIN=localhost
SEP10_WEB_AUTH_DOMAIN=localhost:8080
SEP10_CHALLENGE_TTL_SECONDS=300
AUTH_SESSION_TTL_SECONDS=3600

# ── KYC/KYB provider + advisory decision policy ──────────────────────────────
KYC_PROVIDER=sandbox
KYC_AI_TIMEOUT_MS=3000
KYC_APPROVE_MAX_RISK=0.35
KYC_REJECT_MIN_RISK=0.7
KYC_MIN_CONFIDENCE=0.7

# Ledger ↔ chain reconciliation cadence. Any mismatch blocks the order.
RECONCILIATION_INTERVAL_MS=60000
# deterministic is local/test only. soroban-rpc requires the production adapter.
ESCROW_GATEWAY=deterministic

# ── Dispute auto-resolve thresholds (config, not hardcoded) ─────────────────
AUTO_RESOLVE_MAX_AMOUNT=50000
AUTO_RESOLVE_MIN_CONFIDENCE=0.9

# Temporary local-development KYC approval route. Keep unset outside local dev.
# TEMP_KYC_APPROVAL_PASSWORD=replace-with-a-local-password