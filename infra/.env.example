# StellarTrust infra — shared local-dev environment template.
# Copy to infra/.env. Never add real secrets to this committed template.

NODE_ENV=development
PORT=8080
LOG_LEVEL=info
FRONTEND_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# Local Docker services
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=stellartrust
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/stellartrust
REDIS_URL=redis://redis:6379
AI_SERVICE_URL=http://ai:8000

# Stellar testnet public endpoints
STELLAR_NETWORK=testnet
HORIZON_URL=https://horizon-testnet.stellar.org
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
SIGNER_PROVIDER=local-stub
SIGNER_KEY_REF=local-stub-key-ref

# Local auth, KYC, and Phase 2 reconciliation
AUTH_DEV_BEARER=dev-local-token
SEP10_HOME_DOMAIN=localhost
SEP10_WEB_AUTH_DOMAIN=localhost:8080
SEP10_CHALLENGE_TTL_SECONDS=300
AUTH_SESSION_TTL_SECONDS=3600
KYC_PROVIDER=sandbox
KYC_AI_TIMEOUT_MS=3000
KYC_APPROVE_MAX_RISK=0.35
KYC_REJECT_MIN_RISK=0.7
KYC_MIN_CONFIDENCE=0.7
RECONCILIATION_INTERVAL_MS=60000
AUTO_RESOLVE_MAX_AMOUNT=50000
AUTO_RESOLVE_MIN_CONFIDENCE=0.9

# Optional manual integrations (uncomment only in gitignored infra/.env)
# SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# SUPABASE_PUBLISHABLE_KEY=YOUR_PUBLISHABLE_KEY
# SUPABASE_SECRET_KEY=YOUR_ROTATED_SERVER_SECRET
# SUPABASE_JWKS_URL=https://YOUR_PROJECT.supabase.co/auth/v1/.well-known/jwks.json
# TEMP_KYC_APPROVAL_PASSWORD=CHOOSE_A_LOCAL_ONLY_PASSWORD
