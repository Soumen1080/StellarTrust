# StellarTrust infra — shared local-dev environment template.
# LOCAL DEV ONLY. No real secrets. Production config comes from a secret manager
# and KMS/HSM (Rules.md #2, §8).

# Postgres (docker-compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=stellartrust

# Service URLs on the compose network
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/stellartrust
REDIS_URL=redis://redis:6379
AI_SERVICE_URL=http://ai:8000

# Stellar (testnet locally)
STELLAR_NETWORK=testnet
HORIZON_URL=https://horizon-testnet.stellar.org
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Signing: local stub only in dev; KMS/HSM in staging/prod
SIGNER_PROVIDER=local-stub
